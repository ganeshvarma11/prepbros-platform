{
  "outputDirectory": "dist/public",
  "buildCommand": "pnpm install && pnpm run build",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/:path((?!api/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
